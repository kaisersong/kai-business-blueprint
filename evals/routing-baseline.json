  "boundary_queries": [
    {
      "id": "bnd-01",
      "query": "生成商业蓝图并导出为 PPT",
      "expected_route": "kai-business-blueprint THEN kai-slide-creator",
      "reason": "跨 skill 协作：蓝图生成 + PPT 导出"
    },
    {
      "id": "bnd-02",
      "query": "优化 ROI 策略",
      "expected_route": "ambiguous",
      "ambiguity": "关键词'策略'可能触发 domain-knowledge，但用户可能想要系统架构或纯分析",
      "desired_behavior": "ask user to clarify"
    },
    {
      "id": "bnd-03",
      "query": "帮我分析一下这个方案",
      "expected_route": "ambiguous",
      "ambiguity": "分析不等于生成蓝图，但用户后续可能要求生成",
      "desired_behavior": "analyze first, offer blueprint generation as follow-up"
    },
    {
      "id": "bnd-04",
      "query": "我的 blueprint.json 已经生成好了，帮我导出 drawio",
      "expected_route": "kai-business-blueprint",
      "expected_command": "--export --format drawio",
      "reason": "纯导出，跳过生成步骤"
    },
    {
      "id": "bnd-05",
      "query": "我有个零售项目想看看能怎么规划",
      "expected_route": "ambiguous",
      "ambiguity": "意图模糊，可能是蓝图也可能是文档",
      "desired_behavior": "ask user to clarify: blueprint or document?"
    },
    {
      "id": "bnd-06",
      "query": "基于刚才的蓝图帮我做个报告",
      "expected_route": "kai-business-blueprint THEN kai-report-creator",
      "reason": "跨 skill 协作：projection → report"
    }
